            <div class="form-group">
                <label asp-for="Encomenda.UtilizadorId" class="control-label"></label>
                <select asp-for="Encomenda.UtilizadorId" class ="form-control" asp-items="ViewBag.UtilizadorId"></select>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
