@page
@model FormaFantasia.Web.Pages.Encomendas.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Create</h1>
        
    <h4>Encomenda</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Encomenda.Data" class="control-label"></label>
                <input asp-for="Encomenda.Data" class="form-control" />
