@page
@model FormaFantasia.Web.Pages.Produtos.CreateModel

        @{
        ViewData["Title"] = "Create";
        }
        
        <h1>Create</h1>
        
    <h4>Produto</h4>
    <hr />
    <div class="row">
    <div class="col-md-4">
    <form method="post" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="Produto.Nome" class="control-label"></label>
                <input asp-for="Produto.Nome" class="form-control" />
                <span asp-validation-for="Produto.Nome" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.Descricao" class="control-label"></label>
                <input asp-for="Produto.Descricao" class="form-control" />
                <span asp-validation-for="Produto.Descricao" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.Preco" class="control-label"></label>
                <input asp-for="Produto.Preco" class="form-control" />
                <span asp-validation-for="Produto.Preco" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Produto.Stock" class="control-label"></label>
                <input asp-for="Produto.Stock" class="form-control" />
                <span asp-validation-for="Produto.Stock" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Produto.CategoriaId" class="form-label">Categoria</label>
                <select asp-for="Produto.CategoriaId" asp-items="Model.Categorias" class="form-control">
                    <option value="">-- Seleciona uma categoria --</option>
                </select>
                <span asp-validation-for="Produto.CategoriaId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Fotos do Produto</label>
                <input type="file" name="Fotos" multiple accept="image/*" class="form-control" />
                <small class="text-muted">Podes selecionar várias fotos. A primeira será a principal.</small>
            </div>
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
